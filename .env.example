# ==================== 应用基本配置 ====================
APP_NAME=SmartDocRAG
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql+psycopg://postgres:postgres123@localhost:5432/smartdocrag

# ==================== Redis 配置 (用于 Celery) ====================
REDIS_URL=redis://localhost:6379/0

# ==================== JWT 认证 ====================
SECRET_KEY=your-super-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== LLM 配置 (OpenAI 兼容接口) ====================
LLM_API_BASE=https://api.grok.x.ai/v1
LLM_API_KEY=sk-你的真实key
LLM_MODEL=grok-beta

# ==================== 嵌入模型 ====================
EMBEDDING_MODEL=BAAI/bge-m3

# ==================== RAG 参数 ====================
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
TOP_K=8
SIMILARITY_THRESHOLD=0.75